---
import Layout from '../layouts/Layout.astro';
import TerminalHeader from '../components/TerminalHeader.astro';
---

<Layout title="Crackbot | Independent Cybersecurity Research Group">
  <TerminalHeader 
    title="Crackbot"
    subtitle="Crackbot conducts cybersecurity research, publishes technical analysis, develops security tools and shares actionable threat intelligence to help researchers, defenders and the broader security community."
    statusItems={[
      "Platform Architecture Initialized",
      "Development Infrastructure Online", 
      "GitHub & Vercel Connected",
      "Public Launch In Progress..."
    ]}
  />

  <!-- Focus Areas Grid -->
  <section id="focus" class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 bg-crackbot-900/50 border border-crackbot-700/50 rounded-full px-4 py-1.5 mb-6">
          <span class="terminal-text text-xs text-terminal-green uppercase tracking-wider">CORE FOCUS AREAS</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Research Domains</h2>
        <p class="text-crackbot-400 max-w-2xl mx-auto text-lg">
          Each domain represents a pillar of our research philosophy. Cards marked <span class="text-terminal-green font-mono">ACTIVE</span> have live content - others are in active development.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="focus-grid">

        <article class="card group relative overflow-hidden" style="animation-delay: 0ms" data-area="vuln-research">
          <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-terminal-green/30 to-transparent transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />
          
          <div class="flex items-start gap-4">
            <div class="relative flex-shrink-0 w-14 h-14 rounded-xl bg-crackbot-800/50 border border-crackbot-700/50 flex items-center justify-center group-hover:border-terminal-green/50 group-hover:bg-terminal-green/10 transition-all duration-300">
              <div class="text-terminal-green"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19 14.5m0 0v5.714c0 .597-.237 1.17-.659 1.591L14.25 20.894" /></svg></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-4 mb-3">
                <h3 class="text-lg font-semibold text-white group-hover:text-terminal-green transition-colors">Vulnerability Research</h3>
                <span class="flex-shrink-0 px-2 py-0.5 text-xs font-mono font-medium rounded border bg-terminal-green/20 text-terminal-green border-terminal-green/30 animate-pulse-slow">
                  ACTIVE
                </span>
              </div>
              <p class="text-crackbot-300 text-sm leading-relaxed mb-4">Deep-dive vulnerability analysis, root cause analysis, exploit development, and responsible disclosure coordination with vendors and CERTs.</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">CVE Analysis</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Root Cause</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Exploit Dev</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">RCE</span><span class="px-2 py-0.5 text-xs text-crackbot-500 bg-crackbot-800/50 border border-crackbot-700/50 rounded">+2 more</span>
              </div>
              <a href="#" class="btn btn-ghost text-sm group-hover:justify-start" data-cta="View Research">
                View Research
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          </div>
        </article>

        <article class="card group relative overflow-hidden" style="animation-delay: 100ms" data-area="threat-intel">
          <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-terminal-green/30 to-transparent transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />
          
          <div class="flex items-start gap-4">
            <div class="relative flex-shrink-0 w-14 h-14 rounded-xl bg-crackbot-800/50 border border-crackbot-700/50 flex items-center justify-center group-hover:border-terminal-green/50 group-hover:bg-terminal-green/10 transition-all duration-300">
              <div class="text-terminal-green"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-4 mb-3">
                <h3 class="text-lg font-semibold text-white group-hover:text-terminal-green transition-colors">Threat Intelligence</h3>
                <span class="flex-shrink-0 px-2 py-0.5 text-xs font-mono font-medium rounded border bg-terminal-amber/20 text-terminal-amber border-terminal-amber/30 animate-pulse-slow">
                  BUILDING
                </span>
              </div>
              <p class="text-crackbot-300 text-sm leading-relaxed mb-4">Curated advisories, emerging threat tracking, breach notification monitoring, IOC collection, and defensive intelligence for blue teams.</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">APT Tracking</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">IOC Feeds</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Advisories</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Dark Web</span><span class="px-2 py-0.5 text-xs text-crackbot-500 bg-crackbot-800/50 border border-crackbot-700/50 rounded">+2 more</span>
              </div>
              <a href="#" class="btn btn-ghost text-sm group-hover:justify-start" data-cta="Coming Soon">
                Coming Soon
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          </div>
        </article>

        <article class="card group relative overflow-hidden" style="animation-delay: 200ms" data-area="disclosure">
          <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-terminal-green/30 to-transparent transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />
          
          <div class="flex items-start gap-4">
            <div class="relative flex-shrink-0 w-14 h-14 rounded-xl bg-crackbot-800/50 border border-crackbot-700/50 flex items-center justify-center group-hover:border-terminal-green/50 group-hover:bg-terminal-green/10 transition-all duration-300">
              <div class="text-terminal-green"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" /></svg></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-4 mb-3">
                <h3 class="text-lg font-semibold text-white group-hover:text-terminal-green transition-colors">Responsible Disclosure</h3>
                <span class="flex-shrink-0 px-2 py-0.5 text-xs font-mono font-medium rounded border bg-crackbot-700 text-crackbot-400 border-crackbot-600 ">
                  PLANNED
                </span>
              </div>
              <p class="text-crackbot-300 text-sm leading-relaxed mb-4">Structured vulnerability disclosure program, coordinated vendor communication, and public advisory publication with mitigation guidance.</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">CVD</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Vendor Coord</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Advisories</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">CERT Liaison</span><span class="px-2 py-0.5 text-xs text-crackbot-500 bg-crackbot-800/50 border border-crackbot-700/50 rounded">+2 more</span>
              </div>
              <a href="#" class="btn btn-ghost text-sm group-hover:justify-start" data-cta="Planned">
                Planned
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          </div>
        </article>

        <article class="card group relative overflow-hidden" style="animation-delay: 300ms" data-area="dfir">
          <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-terminal-green/30 to-transparent transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />
          
          <div class="flex items-start gap-4">
            <div class="relative flex-shrink-0 w-14 h-14 rounded-xl bg-crackbot-800/50 border border-crackbot-700/50 flex items-center justify-center group-hover:border-terminal-green/50 group-hover:bg-terminal-green/10 transition-all duration-300">
              <div class="text-terminal-green"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-4 mb-3">
                <h3 class="text-lg font-semibold text-white group-hover:text-terminal-green transition-colors">Digital Forensics & DFIR</h3>
                <span class="flex-shrink-0 px-2 py-0.5 text-xs font-mono font-medium rounded border bg-crackbot-700 text-crackbot-400 border-crackbot-600 ">
                  PLANNED
                </span>
              </div>
              <p class="text-crackbot-300 text-sm leading-relaxed mb-4">Incident response tooling, forensic artifact parsers, timeline analysis, memory forensics, and evidence preservation workflows.</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Memory Forensics</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Disk Analysis</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Timeline</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Artifacts</span><span class="px-2 py-0.5 text-xs text-crackbot-500 bg-crackbot-800/50 border border-crackbot-700/50 rounded">+2 more</span>
              </div>
              <a href="#" class="btn btn-ghost text-sm group-hover:justify-start" data-cta="Planned">
                Planned
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          </div>
        </article>

        <article class="card group relative overflow-hidden" style="animation-delay: 400ms" data-area="malware-analysis">
          <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-terminal-green/30 to-transparent transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />
          
          <div class="flex items-start gap-4">
            <div class="relative flex-shrink-0 w-14 h-14 rounded-xl bg-crackbot-800/50 border border-crackbot-700/50 flex items-center justify-center group-hover:border-terminal-green/50 group-hover:bg-terminal-green/10 transition-all duration-300">
              <div class="text-terminal-green"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-4 mb-3">
                <h3 class="text-lg font-semibold text-white group-hover:text-terminal-green transition-colors">Malware Analysis</h3>
                <span class="flex-shrink-0 px-2 py-0.5 text-xs font-mono font-medium rounded border bg-terminal-amber/20 text-terminal-amber border-terminal-amber/30 animate-pulse-slow">
                  BUILDING
                </span>
              </div>
              <p class="text-crackbot-300 text-sm leading-relaxed mb-4">Static and dynamic malware analysis, family classification, YARA rule development, unpacking, and behavioral profiling.</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Static Analysis</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Dynamic Analysis</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">YARA Rules</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Unpacking</span><span class="px-2 py-0.5 text-xs text-crackbot-500 bg-crackbot-800/50 border border-crackbot-700/50 rounded">+2 more</span>
              </div>
              <a href="#" class="btn btn-ghost text-sm group-hover:justify-start" data-cta="Building">
                Building
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          </div>
        </article>

        <article class="card group relative overflow-hidden" style="animation-delay: 500ms" data-area="ai-security">
          <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-terminal-green/30 to-transparent transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />
          
          <div class="flex items-start gap-4">
            <div class="relative flex-shrink-0 w-14 h-14 rounded-xl bg-crackbot-800/50 border border-crackbot-700/50 flex items-center justify-center group-hover:border-terminal-green/50 group-hover:bg-terminal-green/10 transition-all duration-300">
              <div class="text-terminal-green"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-4 mb-3">
                <h3 class="text-lg font-semibold text-white group-hover:text-terminal-green transition-colors">AI for Cyber Security</h3>
                <span class="flex-shrink-0 px-2 py-0.5 text-xs font-mono font-medium rounded border bg-crackbot-700 text-crackbot-400 border-crackbot-600 ">
                  PLANNED
                </span>
              </div>
              <p class="text-crackbot-300 text-sm leading-relaxed mb-4">LLM-assisted vulnerability discovery, automated triage, intelligent log analysis, and AI-powered threat hunting workflows.</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">LLM Sec</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Auto-Triage</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Vuln Discovery</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Threat Hunting</span><span class="px-2 py-0.5 text-xs text-crackbot-500 bg-crackbot-800/50 border border-crackbot-700/50 rounded">+2 more</span>
              </div>
              <a href="#" class="btn btn-ghost text-sm group-hover:justify-start" data-cta="Research Phase">
                Research Phase
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          </div>
        </article>

        <article class="card group relative overflow-hidden" style="animation-delay: 600ms" data-area="open-tools">
          <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-terminal-green/30 to-transparent transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />
          
          <div class="flex items-start gap-4">
            <div class="relative flex-shrink-0 w-14 h-14 rounded-xl bg-crackbot-800/50 border border-crackbot-700/50 flex items-center justify-center group-hover:border-terminal-green/50 group-hover:bg-terminal-green/10 transition-all duration-300">
              <div class="text-terminal-green"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-4 mb-3">
                <h3 class="text-lg font-semibold text-white group-hover:text-terminal-green transition-colors">Open Source Security Tools</h3>
                <span class="flex-shrink-0 px-2 py-0.5 text-xs font-mono font-medium rounded border bg-terminal-green/20 text-terminal-green border-terminal-green/30 animate-pulse-slow">
                  ACTIVE
                </span>
              </div>
              <p class="text-crackbot-300 text-sm leading-relaxed mb-4">Production-grade security tools released under permissive licenses — scanners, parsers, analyzers, and automation frameworks.</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">CLI Tools</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Scanners</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Parsers</span><span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">Automation</span><span class="px-2 py-0.5 text-xs text-crackbot-500 bg-crackbot-800/50 border border-crackbot-700/50 rounded">+2 more</span>
              </div>
              <a href="#" class="btn btn-ghost text-sm group-hover:justify-start" data-cta="View Tools">
                View Tools
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          </div>
        </article>

        <article class="card group relative overflow-hidden" style="animation-delay: 700ms" data-area="education">
