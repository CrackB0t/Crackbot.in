---
import Layout from '../layouts/Layout.astro';
import TerminalHeader from '../components/sections/TerminalHeader.astro';
import FocusAreas from '../components/sections/FocusAreas.astro';
import Philosophy from '../components/sections/Philosophy.astro';
import CTA from '../components/sections/CTA.astro';
import principlesData from '../data/principles.json';
---

<Layout title="Crackbot | Independent Cybersecurity Research Group">
  <TerminalHeader 
    title="Crackbot"
    subtitle="Crackbot conducts cybersecurity research, publishes technical analysis, develops security tools and shares actionable threat intelligence to help researchers, defenders and the broader security community."
    statusItems={[
      "Platform Architecture Initialized",
      "Development Infrastructure Online", 
      "GitHub & Vercel Connected",
      "Public Launch In Progress..."
    ]}
  />

  <FocusAreas />
  <Philosophy principles={principlesData.principles} codeBlock={principlesData.codeBlock} />
  <CTA />

  <!-- Mobile footer CTA bar -->
  <div class="fixed bottom-0 left-0 right-0 bg-crackbot-950/95 backdrop-blur-sm border-t border-crackbot-700/50 px-4 py-3 z-50 md:hidden">
    <div class="max-w-7xl mx-auto flex items-center justify-between text-sm">
      <span class="text-crackbot-400">Crackbot Platform • Under Active Development</span>
      <a href="https://github.com/CrackB0t" target="_blank" rel="noopener" class="text-terminal-green hover:text-terminal-green-light font-mono">GitHub →</a>
    </div>
  </div>
</Layout>