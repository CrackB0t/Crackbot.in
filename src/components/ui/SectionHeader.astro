---
// SectionHeader.astro - Reusable section header
interface Props {
  label: string;
  title: string;
  description?: string;
  class?: string;
}

const { label, title, description, class: className = '' } = Astro.props;
---

<div class={`text-center mb-16 ${className}`}>
  <div class="inline-flex items-center gap-2 bg-crackbot-900/50 border border-crackbot-700/50 rounded-full px-4 py-1.5 mb-6">
    <span class="terminal-text text-xs text-terminal-green uppercase tracking-wider">{label}</span>
  </div>
  <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">{title}</h2>
  {description && <p class="text-crackbot-400 max-w-2xl mx-auto text-lg leading-relaxed">{description}</p>}
</div>