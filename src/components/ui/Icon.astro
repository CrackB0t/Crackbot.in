---
// Icon.astro - SVG icon system (handles both stroke and fill icons)
interface Props {
  name: string;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
}

const { name, size = 'md', class: className = '' } = Astro.props;

const sizes = {
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
  xl: 'w-8 h-8'
};

// Icons that use fill (no stroke)
const fillIcons = ['github', 'twitter', 'discord'];

