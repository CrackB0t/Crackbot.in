---
// FocusCard.astro - Professional research area card
import Badge from './Badge.astro';
import Icon from './Icon.astro';
import Button from './Button.astro';

interface FocusArea {
  id: string;
  title: string;
  icon: string;
  description: string;
  tags: string[];
  status: 'active' | 'building' | 'planned';
  cta: string;
}

interface Props {
  area: FocusArea;
  index: number;
}

const { area, index } = Astro.props;
const delay = index * 100;
---

<article 
  class="research-card group relative overflow-hidden"
  style={`animation-delay: ${delay}ms`}
  data-area={area.id}
>
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-terminal-green/30 to-transparent transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />
  
  <div class="flex items-start gap-4 sm:gap-5">
    <div class="relative flex-shrink-0 w-14 h-14 rounded-xl bg-crackbot-800/50 border border-crackbot-700/50 flex items-center justify-center group-hover:border-terminal-green/50 group-hover:bg-terminal-green/10 transition-all duration-300">
      <Icon name={area.icon} size="lg" />
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-start justify-between gap-4 mb-3">
        <h3 class="text-lg font-semibold text-white group-hover:text-terminal-green transition-colors">{area.title}</h3>
        <Badge variant={area.status} pulse={area.status !== 'planned'}>
          {area.status.toUpperCase()}
        </Badge>
      </div>
      <p class="text-crackbot-300 text-sm leading-relaxed mb-4">{area.description}</p>
      <div class="flex flex-wrap gap-1.5 mb-4">
        {area.tags.slice(0, 4).map(tag => (
          <span class="px-2.5 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded-lg group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">{tag}</span>
        ))}
        {area.tags.length > 4 && (
          <span class="px-2.5 py-0.5 text-xs text-crackbot-500 bg-crackbot-800/50 border border-crackbot-700/50 rounded-lg">+{area.tags.length - 4} more</span>
        )}
      </div>
      <Button 
        variant="ghost" 
        size="sm" 
        href="#" 
        icon="arrow-right" 
        iconPosition="right"
        class="group-hover:justify-start"
      >
        {area.cta}
      </Button>
    </div>
  </div>
</article>