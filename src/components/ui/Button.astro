---
// Button.astro - Reusable button component
import Icon from './Icon.astro';

interface Props {
  variant?: 'primary' | 'ghost' | 'outline';
  href?: string;
  class?: string;
  icon?: string;
  iconPosition?: 'left' | 'right';
  size?: 'sm' | 'md' | 'lg';
  target?: string;
  rel?: string;
  type?: 'button' | 'submit' | 'reset';
}

const {
  variant = 'primary',
  href,
  class: className = '',
  icon,
  iconPosition = 'left',
  size = 'md',
  target,
  rel,
  type = 'button'
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center gap-2 font-medium transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-terminal-green focus:ring-offset-2 focus:ring-offset-crackbot-950 rounded-xl';

const variants = {
  primary: 'bg-terminal-green text-crackbot-950 hover:bg-terminal-green-bright hover:shadow-[0_0_20px_rgba(0,212,170,0.3)]',
  ghost: 'bg-crackbot-800/50 border border-crackbot-700/50 text-crackbot-200 hover:bg-crackbot-700/50 hover:border-terminal-green/30 hover:text-terminal-green',
  outline: 'border-2 border-terminal-green text-terminal-green hover:bg-terminal-green/10'
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-sm',
  lg: 'px-8 py-4 text-base'
};

const isLink = !!href;
const Tag = isLink ? 'a' : 'button';
const props = isLink
  ? { href, target, rel: rel || (target === '_blank' ? 'noopener noreferrer' : undefined) }
  : { type };

---

<Tag {...props} class={`${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`}>
  {icon && iconPosition === 'left' && <Icon name={icon} size={size === 'sm' ? 'sm' : 'md'} />}
  <slot />
  {icon && iconPosition === 'right' && <Icon name={icon} size={size === 'sm' ? 'sm' : 'md'} />}
</Tag>