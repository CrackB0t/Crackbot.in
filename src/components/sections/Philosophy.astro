---
// Philosophy.astro - Research philosophy section
import Icon from '../ui/Icon.astro';
import SectionHeader from '../ui/SectionHeader.astro';

interface Props {
  principles: any[];
  codeBlock: string;
}

const { principles, codeBlock } = Astro.props;
---

<section id="philosophy" class="py-20 px-4 sm:px-6 lg:px-8 bg-crackbot-900/30 border-y border-crackbot-700/50">
  <div class="max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      <div class="order-2 lg:order-1">
        <SectionHeader
          label="RESEARCH PHILOSOPHY"
          title="Every Finding Should Educate. Every Vulnerability Should Improve Security."
          description="We believe in collaboration over competition, responsible disclosure over publicity, and knowledge sharing over knowledge hoarding. Our work is guided by principles that put the defender first."
        />
        
        <div class="space-y-4">
          {principles.map(principle => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-terminal-green/10 border border-terminal-green/20 flex items-center justify-center">
                <Icon name="check" size="sm" />
              </div>
              <div>
                <h4 class="font-semibold text-white">{principle.title}</h4>
                <p class="text-crackbot-400 text-sm mt-1">{principle.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <div class="relative order-1 lg:order-2">
        <div class="bg-crackbot-950/90 backdrop-blur-sm border border-crackbot-700/50 rounded-2xl p-6 md:p-8">
          <div class="mb-6">
            <div class="flex items-center gap-2 mb-4">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-terminal-red" />
                <div class="w-3 h-3 rounded-full bg-terminal-amber" />
                <div class="w-3 h-3 rounded-full bg-terminal-green" />
              </div>
              <span class="terminal-text text-xs text-crackbot-400">principles.md</span>
            </div>
          </div>
          <pre class="font-mono text-sm text-crackbot-200 overflow-x-auto"><code>{codeBlock}</code></pre>
        </div>
      </div>
    </div>
  </div>
</section>