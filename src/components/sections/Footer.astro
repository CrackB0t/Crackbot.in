---
// Footer.astro - Site footer
import siteData from '../../data/site.json';
import Icon from '../ui/Icon.astro';

const site = siteData;
---

<footer class="border-t border-crackbot-800 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3 text-crackbot-400">
        <span class="terminal-text text-sm">system@crackbot:~$</span>
        <span class="text-xs opacity-70">Independent Cybersecurity Research Group</span>
      </div>
      <div class="flex items-center gap-6 text-sm text-terminal-green">
        <a href={site.github} target="_blank" rel="noopener noreferrer" class="hover:text-terminal-green transition-colors flex items-center gap-1 text-terminal-green">
          <Icon name="github" size="sm" class="text-terminal-green" />
          GitHub
        </a>
        <a href={site.twitter} target="_blank" rel="noopener noreferrer" class="hover:text-terminal-green transition-colors text-terminal-green">Twitter</a>
        <a href={site.discord} target="_blank" rel="noopener noreferrer" class="hover:text-terminal-green transition-colors text-terminal-green">Discord</a>
      </div>
    </div>
    <p class="mt-4 text-center text-xs text-crackbot-500">© {new Date().getFullYear()} {site.name} • {site.tagline}</p>
  </div
</footer>