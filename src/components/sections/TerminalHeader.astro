---
// TerminalHeader.astro - Professional hero (clean, no gimmicks)
import Button from '../ui/Button.astro';

interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "Crackbot", 
  subtitle = "Independent Cybersecurity Research Group" 
} = Astro.props;
---

<header class="hero relative min-h-[90vh] flex items-center justify-center px-4 sm:px-6 lg:px-8 pt-16 pb-20 overflow-hidden">
  <!-- Subtle background atmosphere -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-b from-crackbot-950 via-crackbot-900 to-crackbot-950" />
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-terminal-green/5 rounded-full blur-3xl" />
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-terminal-green/3 rounded-full blur-3xl" />
  </div>

  <div class="relative z-10 max-w-4xl mx-auto text-center">
    <!-- Status badge -->
    <div class="inline-flex items-center gap-2 bg-crackbot-900/50 border border-crackbot-700/50 rounded-full px-4 py-1.5 mb-8 text-xs sm:text-sm">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-terminal-green opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-terminal-green"></span>
      </span>
      <span class="font-mono text-terminal-green uppercase tracking-wider">ACTIVE RESEARCH PLATFORM</span>
    </div>

    <!-- Main headline -->
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold text-white tracking-tight mb-6 font-mono leading-tight">
      <span class="text-terminal-green">{title}</span>
    </h1>
    <p class="text-base sm:text-lg md:text-xl text-crackbot-400 max-w-2xl mx-auto mb-12 leading-relaxed font-light">
      {subtitle}
    </p>

    <!-- Primary CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <Button size="lg" icon="github" iconPosition="left" href="https://github.com/CrackB0t" target="_blank" rel="noopener">
        GitHub
      </Button>
      <Button variant="outline" size="lg" href="mailto:support@crackbot.in">
        Contact
      </Button>
    </div>

    <!-- Trust indicators -->
    <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-8 text-sm text-crackbot-500">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-terminal-green" />
        <span>Open Source</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-terminal-green" />
        <span>Responsible Disclosure</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-terminal-green" />
        <span>Community Driven</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator (mobile only) -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce text-crackbot-500 md:hidden">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</header>

<style>
  .bg-radial-glow {
    background-image: radial-gradient(ellipse at 50% 0%, rgba(0,212,170,0.15) 0%, transparent 70%);
  }
  .bg-grid-pattern {
    background-image: 
      linear-gradient(rgba(0,212,170,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,170,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
  }
  
  .animate-scanline {
    animation: scanline 3s linear infinite;
  }
  @keyframes scanline {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100vh); }
  }
  
  .terminal-red { background-color: #ff4757; }
  .terminal-amber { background-color: #ffb800; }
  .terminal-green { background-color: #00d4aa; }
</style>