---
// TerminalHeader.astro - Terminal-style hero header (responsive)
import Icon from '../ui/Icon.astro';
import Button from '../ui/Button.astro';

interface Props {
  title?: string;
  subtitle?: string;
  statusItems?: string[];
}

const { 
  title = "Crackbot", 
  subtitle = "Independent Cybersecurity Research Group",
  statusItems = [] 
} = Astro.props;
---

<header class="terminal-header relative min-h-[90vh] flex flex-col items-center justify-center px-4 sm:px-6 lg:px-8 pt-12 pb-16">
  <!-- Animated background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute inset-0 bg-radial-glow" />
    <div class="absolute inset-0 bg-grid-pattern opacity-50" />
    <div class="absolute inset-0 animate-scanline bg-gradient-to-b from-transparent via-terminal-green/5 to-transparent" style="height: 2px;" />
  </div>

  <!-- Terminal header bar -->
  <div class="relative z-10 w-full max-w-4xl mb-10">
    <div class="bg-crackbot-950/90 backdrop-blur-sm border border-crackbot-700/50 rounded-t-xl px-4 py-3 flex items-center gap-2">
      <div class="flex gap-1.5">
        <div class="w-3 h-3 rounded-full bg-terminal-red" />
        <div class="w-3 h-3 rounded-full bg-terminal-amber" />
        <div class="w-3 h-3 rounded-full bg-terminal-green" />
      </div>
      <span class="terminal-text text-xs ml-2 flex-1 text-crackbot-400">system@crackbot:~$</span>
      <span class="terminal-text text-xs text-crackbot-500">cat /etc/crackbot/mission</span>
      <kbd class="px-1.5 py-0.5 bg-crackbot-800 border border-crackbot-700 rounded text-xs text-crackbot-400 ml-auto">ENTER</kbd>
    </div>
    <div class="bg-crackbot-950/90 backdrop-blur-sm border border-crackbot-700/50 border-t-0 rounded-b-xl px-4 py-4 font-mono text-sm text-crackbot-200 whitespace-pre-wrap">
      <span class="text-terminal-green">MISSION:</span> Independent cybersecurity research, responsible disclosure, open tooling, and community-driven threat intelligence.
      <br /><span class="text-terminal-green">STATUS:</span> Platform Architecture Initialized • Development Infrastructure Online • GitHub & Vercel Connected • Public Launch In Progress...
    </div>
  </div>

  <!-- Main content -->
  <div class="relative z-10 w-full max-w-4xl text-center">
    <div class="inline-flex items-center gap-2 bg-crackbot-900/50 border border-crackbot-700/50 rounded-full px-4 py-1.5 mb-6">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-terminal-green opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-terminal-green"></span>
      </span>
      <span class="terminal-text text-xs text-terminal-green uppercase tracking-wider">PLATFORM STATUS • UNDER ACTIVE DEVELOPMENT</span>
    </div>

    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold text-white tracking-tight mb-4 font-mono leading-tight">
      <span class="text-terminal-green">{title}</span>
    </h1>
    <p class="text-base sm:text-lg md:text-xl text-crackbot-300 max-w-2xl mx-auto mb-10 leading-relaxed font-light">
      {subtitle}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
      <Button size="lg" icon="github" iconPosition="left" href="https://github.com/CrackB0t" target="_blank" rel="noopener">
        GitHub
      </Button>
      <Button variant="ghost" size="lg" href="mailto:system@crackbot.in">
        Contact
      </Button>
    </div>

    <!-- Status indicators -->
    <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-6 text-sm">
      {statusItems.map(item => (
        <div class="flex items-center gap-2 text-crackbot-400">
          <span class="w-2 h-2 rounded-full bg-terminal-green animate-pulse" />
          <span>{item}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce text-crackbot-500 md:block hidden">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</header>

<style>
  .bg-radial-glow {
    background-image: radial-gradient(ellipse at 50% 0%, rgba(0,212,170,0.15) 0%, transparent 70%);
  }
  .bg-grid-pattern {
    background-image: 
      linear-gradient(rgba(0,212,170,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,170,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
  }
  
  .animate-scanline {
    animation: scanline 3s linear infinite;
  }
  @keyframes scanline {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100vh); }
  }
  
  .terminal-red { background-color: #ff4757; }
  .terminal-amber { background-color: #ffb800; }
  .terminal-green { background-color: #00d4aa; }
</style>