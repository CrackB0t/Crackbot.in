---
interface Props {
  area: {
    id: string;
    title: string;
    icon: string;
    description: string;
    tags: string[];
    status: "active" | "building" | "planned";
    cta: string;
  };
  index: number;
}
const { area, index } = Astro.props;

const statusConfig = {
  active: { label: "ACTIVE", class: "bg-terminal-green/20 text-terminal-green border-terminal-green/30", pulse: true },
  building: { label: "BUILDING", class: "bg-terminal-amber/20 text-terminal-amber border-terminal-amber/30", pulse: true },
  planned: { label: "PLANNED", class: "bg-crackbot-700 text-crackbot-400 border-crackbot-600", pulse: false }
};
const status = statusConfig[area.status];

const icons = {
  "bug": <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19 14.5m0 0v5.714c0 .597-.237 1.17-.659 1.591L14.25 20.894" /></svg>,
  "radar": <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>,
  "shield-alert": <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" /></svg>,
  "search": <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>,
  "terminal": <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>,
  "cloud": <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>,
  "target": <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>,
  "users": <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
};
---
<article class="card group relative overflow-hidden" style="animation-delay: {index * 100}ms" data-area={area.id}>
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-terminal-green/30 to-transparent transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />
  
  <div class="flex items-start gap-4">
    <div class="relative flex-shrink-0 w-14 h-14 rounded-xl bg-crackbot-800/50 border border-crackbot-700/50 flex items-center justify-center group-hover:border-terminal-green/50 group-hover:bg-terminal-green/10 transition-all duration-300">
      <div class="text-terminal-green">{icons[area.icon as keyof typeof icons]}</div>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-start justify-between gap-4 mb-3">
        <h3 class="text-lg font-semibold text-white group-hover:text-terminal-green transition-colors">{area.title}</h3>
        <span class="flex-shrink-0 px-2 py-0.5 text-xs font-mono font-medium rounded border {status.class} {status.pulse ? 'animate-pulse-slow' : ''}">
          {status.label}
        </span>
      </div>
      <p class="text-crackbot-300 text-sm leading-relaxed mb-4">{area.description}</p>
      <div class="flex flex-wrap gap-1.5 mb-4">
        {area.tags.slice(0, 4).map(tag => (
          <span class="px-2 py-0.5 text-xs text-crackbot-400 bg-crackbot-800/50 border border-crackbot-700/50 rounded group-hover:border-terminal-green/30 group-hover:text-terminal-green transition-all">{tag}</span>
        ))}
        {area.tags.length > 4 && <span class="px-2 py-0.5 text-xs text-crackbot-500 bg-crackbot-800/50 border border-crackbot-700/50 rounded">+{area.tags.length - 4} more</span>}
      </div>
      <a href="#" class="btn btn-ghost text-sm group-hover:justify-start" data-cta={area.cta}>
        {area.cta}
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </div>
</article>